PORT=3000
NUTANIX_PC_HOST=pc.example.local
NUTANIX_USERNAME=admin
NUTANIX_PASSWORD=change-me
NUTANIX_TLS_SKIP_VERIFY=true
# Per-request timeout (ms) for outbound calls to Prism. Bump this if you
# see "Failed to list VMs. timeout of NNNNms exceeded" against a slow PC.
NUTANIX_API_TIMEOUT_MS=30000

# =====================================================================
# Multi-user deployment (HTTPS + per-VM chat). Defaults to false, which
# keeps the original single-user HTTP behaviour unchanged.
# =====================================================================
NRCC_MULTI_USER=false
# TLS material for multi-user mode. Leave both blank to auto-generate a
# self-signed cert at NRCC_TLS_CERT_DIR (default ./certs/) on first start.
# The SHA-256 fingerprint of the cert in use is logged at startup so an
# operator can pin / verify it.
NRCC_TLS_CERT=
NRCC_TLS_KEY=
NRCC_TLS_CERT_DIR=./certs
# Chat ring buffer (messages per VM channel kept in memory). Chat history
# is in-memory only and lost when the NRCC server restarts.
NRCC_CHAT_BUFFER=200

# =====================================================================
# Per-VM screenshots. Available in both single-user and multi-user mode.
# Subfolders inside each VM directory are supported (created from the
# browser); the per-VM cap below is enforced across the whole tree.
# =====================================================================
# Server-side screenshot folder (one subfolder per VM UUID).
NRCC_SCREENSHOTS_DIR=./screenshots
# Maximum screenshots retained per VM (oldest pruned automatically).
NRCC_SCREENSHOT_MAX_PER_VM=100

# =====================================================================
# Per-VM session recordings (10 fps WebM/VP9 by default). Available in
# both single-user and multi-user mode. The browser captures the
# console canvas and streams 2-second chunks to the server.
# =====================================================================
# Server-side recordings folder (one subfolder per VM UUID, plus an
# internal _tmp/ for in-flight chunked uploads which is swept hourly).
NRCC_RECORDINGS_DIR=./recordings
# Frames-per-second the browser captureStream() pulls from the canvas.
NRCC_RECORDING_FPS=10
# Target video bitrate in bits per second. 600 kbps comfortably fits a
# 1080p console at 10 fps; bump for higher fidelity.
NRCC_RECORDING_BITRATE=600000
# Hard cap on a single recording in bytes (default 500 MB). If the
# browser keeps streaming past this the server aborts the recording
# and discards the temp file.
NRCC_RECORDING_MAX_BYTES=524288000
# Maximum recordings retained per VM (oldest pruned automatically).
NRCC_RECORDING_MAX_PER_VM=50

# =====================================================================
# Global script library. Plain-text snippets that the browser can copy
# to the clipboard with a single click. Visible to every signed-in
# user; everyone can read, edit, and delete every script.
# =====================================================================
# Server-side scripts folder. Subfolders are supported.
NRCC_SCRIPTS_DIR=./scripts
# Maximum size of a single script body in bytes (default 256 KB).
NRCC_SCRIPT_MAX_BYTES=262144
