PORT=3000
NUTANIX_PC_HOST=pc.example.local
NUTANIX_USERNAME=admin
NUTANIX_PASSWORD=change-me
NUTANIX_TLS_SKIP_VERIFY=true
# Per-request timeout (ms) for outbound calls to Prism. Bump this if you
# see "Failed to list VMs. timeout of NNNNms exceeded" against a slow PC.
NUTANIX_API_TIMEOUT_MS=30000

# =====================================================================
# Multi-user deployment (HTTPS + per-VM chat). Defaults to false, which
# keeps the original single-user HTTP behaviour unchanged.
# =====================================================================
NRCC_MULTI_USER=false
# TLS material for multi-user mode. Leave both blank to auto-generate a
# self-signed cert at NRCC_TLS_CERT_DIR (default ./certs/) on first start.
# The SHA-256 fingerprint of the cert in use is logged at startup so an
# operator can pin / verify it.
NRCC_TLS_CERT=
NRCC_TLS_KEY=
NRCC_TLS_CERT_DIR=./certs
# Chat ring buffer (messages per VM channel kept in memory). Chat history
# is in-memory only and lost when the NRCC server restarts.
NRCC_CHAT_BUFFER=200

# =====================================================================
# Per-VM screenshots. Available in both single-user and multi-user mode.
# Subfolders inside each VM directory are supported (created from the
# browser); the per-VM cap below is enforced across the whole tree.
# =====================================================================
# Server-side screenshot folder (one subfolder per VM UUID).
NRCC_SCREENSHOTS_DIR=./screenshots
# Maximum screenshots retained per VM (oldest pruned automatically).
NRCC_SCREENSHOT_MAX_PER_VM=100

# =====================================================================
# Per-VM session recordings (10 fps WebM/VP9 by default). Available in
# both single-user and multi-user mode. The browser captures the
# console canvas and streams 2-second chunks to the server.
# =====================================================================
# Server-side recordings folder (one subfolder per VM UUID, plus an
# internal _tmp/ for in-flight chunked uploads which is swept hourly).
NRCC_RECORDINGS_DIR=./recordings
# Frames-per-second the browser captureStream() pulls from the canvas.
NRCC_RECORDING_FPS=10
# Target video bitrate in bits per second. 600 kbps comfortably fits a
# 1080p console at 10 fps; bump for higher fidelity.
NRCC_RECORDING_BITRATE=600000
# Hard cap on a single recording in bytes (default 500 MB). If the
# browser keeps streaming past this the server aborts the recording
# and discards the temp file.
NRCC_RECORDING_MAX_BYTES=524288000
# Maximum recordings retained per VM (oldest pruned automatically).
NRCC_RECORDING_MAX_PER_VM=50

# =====================================================================
# Global script library. Plain-text snippets that the browser can copy
# to the clipboard with a single click. Visible to every signed-in
# user; everyone can read, edit, and delete every script.
# =====================================================================
# Server-side scripts folder. Subfolders are supported.
NRCC_SCRIPTS_DIR=./scripts
# Maximum size of a single script body in bytes (default 256 KB).
NRCC_SCRIPT_MAX_BYTES=262144

# =====================================================================
# Activity logging. Master switch for the optional weekly-rotated log
# file written when users opt in via Settings -> "Record my logins and
# console activity". Server-emitted events (login / console-open /
# console-close / chat) are written whenever NRCC_LOGGING=true.
# Client-emitted events (paste / screenshot / recording / script copy /
# settings.saved) require both NRCC_LOGGING=true AND the per-user
# toggle.
# =====================================================================
NRCC_LOGGING=false
# Directory the weekly log files (nrcc-YYYY-Www.log) live in. Created
# on first start when NRCC_LOGGING=true.
NRCC_LOGS_DIR=./logs

# =====================================================================
# In-app self-update from GitHub. The Settings dialog gets a blue
# "Update" button beside the build number that compares the running
# APP_VERSION against build.info on the configured branch and, on
# confirmation, runs git pull / clone-swap + npm install + restart.
# Set NRCC_UPDATE_ENABLED=false on locked-down installs to hide the
# button and disable the /api/update/* routes. Requires `git` on PATH
# and a process supervisor that restarts node when the server exits.
# =====================================================================
NRCC_UPDATE_ENABLED=true
NRCC_UPDATE_REPO=https://github.com/script-repo/ntnx-console-client
NRCC_UPDATE_BRANCH=main
# Cache TTL (ms) for /api/update/check results. The client's
# background "update available" badge poll and any concurrent users
# share this cache so raw.githubusercontent.com is hit at most once
# per window. The Update button bypasses the cache via ?force=1.
# Minimum 60 000 ms.
NRCC_UPDATE_CHECK_TTL_MS=300000

# =====================================================================
# Beta: VM port-scan probe. After the VM list arrives the client
# batches the VM IPs to /api/probe/ports; the server TCP-dials each
# (vm, ip, port) tuple and caches the result. The cache is also the
# SSRF guard for /api/ssh/start. Disable with NRCC_PROBE_ENABLED=false
# on installs whose SOC objects to the (very low) TCP probe noise.
# =====================================================================
NRCC_PROBE_ENABLED=true
# Comma-separated list of TCP ports to probe per VM IP. Future-proofed
# for additions like 5985 (WinRM); keep narrow to limit probe noise.
NRCC_PROBE_PORTS=22,3389
# Per-socket connect timeout, in milliseconds.
NRCC_PROBE_TIMEOUT_MS=2000
# Global semaphore over (vm, ip, port) dials. 200 VMs * 2 ports * 4 IPs
# = 1600 dials would otherwise all happen at once.
NRCC_PROBE_CONCURRENCY=20
# How long a per-VM probe result is reused before the next request
# triggers a re-probe. Also bounds the SSH SSRF allow-list lifetime.
NRCC_PROBE_CACHE_TTL_MS=120000
# Cap the number of IPs fanned out to per VM (multi-NIC VMs commonly
# expose 2-3; we cap at 4 so a misconfigured guest doesn't burn the
# probe budget on link-local fluff).
NRCC_PROBE_MAX_IPS_PER_VM=4

# =====================================================================
# Beta: SSH browser console. POST /api/ssh/start authorises a single
# SSH session (host MUST match an IP returned by /api/probe/ports for
# that VM) and the WS upgrade at /ws-ssh/<id> opens the actual
# ssh2.Client.shell() and pipes raw bytes to the browser's xterm.js
# terminal. Disable with NRCC_SSH_ENABLED=false on locked-down installs.
# =====================================================================
NRCC_SSH_ENABLED=true
# Idle timeout for an unused SSH session id (ms). Sessions are also
# torn down when the WS closes; this only protects against /api/ssh/start
# requests whose WS upgrade never arrives.
NRCC_SSH_IDLE_TIMEOUT_MS=900000
# Hard cap on simultaneous SSH sessions per server process. The
# browser tab count is the natural limit; this is just defence in depth.
NRCC_SSH_MAX_SESSIONS=64
# How long ssh2 waits for the server to complete its handshake before
# giving up.
NRCC_SSH_READY_TIMEOUT_MS=15000

# =====================================================================
# Beta: RDP browser console. POST /api/rdp/start authorises a single
# RDP session (host MUST match an IP returned by /api/probe/ports for
# that VM, same SSRF guard as SSH) and the WS upgrade at /ws-rdp/<id>
# opens a TCP connection to the locally-installed `guacd` (Apache
# Guacamole proxy daemon), runs the Guacamole protocol handshake with
# the cached credentials, and pipes raw protocol bytes to the
# browser's guacamole-common-js client. guacd is NOT bundled with
# NRCC -- install it natively via your OS package manager
# (`apt install guacd`, `dnf install guacd`,
# `brew install guacamole-server`). The README has the full list.
# Disable with NRCC_RDP_ENABLED=false on installs that don't want
# the feature available at all.
# =====================================================================
NRCC_RDP_ENABLED=true
# Idle timeout for an unused RDP session id (ms).
NRCC_RDP_IDLE_TIMEOUT_MS=900000
# Hard cap on simultaneous RDP sessions per server process.
NRCC_RDP_MAX_SESSIONS=64
# guacd location. Defaults match the upstream package which listens
# on 127.0.0.1:4822 -- only override if you've moved guacd off-box or
# rebuilt it on a custom port.
NRCC_GUACD_HOST=127.0.0.1
NRCC_GUACD_PORT=4822
# How long we wait for guacd to TCP-accept and reply with `args;`
# before aborting the handshake.
NRCC_GUACD_CONNECT_TIMEOUT_MS=15000
# Default RDP framebuffer dimensions (the browser overrides these
# based on actual screen-pane size in /api/rdp/start, so these are
# only the fallback when the client forgets to send them).
NRCC_RDP_WIDTH=1280
NRCC_RDP_HEIGHT=800
NRCC_RDP_DPI=96
# RDP security mode passed to guacd: any | rdp | nla | tls | vmconnect.
# "any" lets guacd negotiate against whatever the host advertises and
# is the right choice for a mixed lab.
NRCC_RDP_SECURITY=any
# Skip server certificate validation. Lab default is true; set to
# false if you have a real PKI and want guacd to enforce it.
NRCC_RDP_IGNORE_CERT=true

# =====================================================================
# Beta: VM folders. Group VMs into folders backed by Prism categories
# under the reserved key "NTNXFolderPath" (dot-delimited paths, e.g.
# "Production.Linux.Web"). The folder tree is rendered from Prism's
# category catalog; folder writes go back to Prism as real
# categories so the membership survives a NRCC reinstall and is
# visible in the Prism UI too. Set to false on locked-down installs
# that don't want NRCC mutating cluster category state -- the
# /api/folders/* and /api/vms/folder* routes then return 503 and
# the sidebar folder pane disappears.
# =====================================================================
NRCC_VM_FOLDERS_ENABLED=true

# =====================================================================
# Beta: AudioPatch portal. Embeds a CC-Peep-style audio portal so VM
# agents (deploy/audiopatch/) can register and admins can "patch in"
# to a VM's audio (output/input/both) from the action pane + PatchBay.
# This is the server-side master switch; it defaults ON so the routes
# exist out of the box, but the feature stays invisible until a user
# ticks "AudioPatch" under Settings -> Show beta features (it does NOT
# auto-enable with the other beta features). Set to false to hard-
# disable the portal cluster-wide -- the /ws-audiopatch/* upgrades and
# /api/audiopatch/* routes then refuse connections.
# =====================================================================
NRCC_AUDIOPATCH_ENABLED=true
# Shared secret a VM agent must present (?token=...) to register. Leave
# empty for an open lab portal (a one-time warning is logged). Set a
# strong value in shared/production deployments.
NRCC_AUDIOPATCH_TOKEN=
# Safety limits for the in-memory registry / relay.
NRCC_AUDIOPATCH_MAX_CLIENTS=256
NRCC_AUDIOPATCH_MAX_ADMINS=256
# A VM agent that misses heartbeats for this long (ms) is dropped from
# PatchBay so stale VMs don't linger.
NRCC_AUDIOPATCH_CLIENT_TTL_MS=45000
# Largest PCM frame (bytes) the portal will relay; oversized frames are
# dropped to protect the server.
NRCC_AUDIOPATCH_MAX_FRAME_BYTES=262144
